# ============================================================
# .gitignore – PentestBox
# ============================================================

# ---- Secrets et configuration sensible ----
.env
*.key
*.pem
*.crt
*.p12

# ---- Python ----
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ---- Virtual environments ----
.venv/
venv/
env/
ENV/
.poetry/

# ---- IDE ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- Docker ----
docker/volumes/

# ---- Rapports générés (locaux) ----
/tmp/reports/
*.pdf
*.html.bak

# ---- Logs ----
*.log
logs/

# ---- OS ----
.DS_Store
Thumbs.db
desktop.ini

# ---- MinIO local data ----
minio_data/

# ---- Node (si utilisé) ----
node_modules/
